# ===== Secrets (put real values in .env.local or system env) =====
DASHSCOPE_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
BACKEND_API_KEY=

# ===== LLM =====
QWEN_MODEL_NAME=qwen-plus-2025-12-01
QWEN_TEMPERATURE=0.1
QWEN_MAX_TOKENS=2000
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TIMEOUT=30
QWEN_MAX_RETRIES=2

# ===== Report LLM =====
REPORT_QWEN_TIMEOUT=180
REPORT_QWEN_MAX_RETRIES=1
REPORT_MAX_TOKENS=3200
REPORT_INPUT_MAX_CHARS=14000

# ===== Search =====
SEARCH_BACKEND=serper
MAX_SEARCH_RESULTS=5
SEARCH_HTTP_TIMEOUT_S=60
SEARCH_HTTP_RETRIES=3
SEARCH_LOG_QUERIES=false

# ===== Embedding =====
EMBEDDING_PROVIDER=dashscope
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# ===== Enhancers =====
ENABLE_HYDE=true
HYDE_ANSWER_LENGTH=medium
ENABLE_MQE=false
MQE_NUM_VARIANTS=2

# ===== Research evaluation settings =====
METRIC_VALIDITY_WEIGHT=0.20
METRIC_SATURATION_WEIGHT=0.25
METRIC_DIVERSITY_WEIGHT=0.15
METRIC_CONFLICT_WEIGHT=0.05
METRIC_FACT_DENSITY_WEIGHT=0.20
METRIC_NOVELTY_WEIGHT=0.15
TASK_STORAGE_THRESHOLD=80
MIN_TASK_STORAGE_THRESHOLD=65
TASK_STORAGE_THRESHOLD_DECAY_PER_CYCLE=6
CYCLE_CONTINUE_THRESHOLD=75
MAX_RESEARCH_CYCLES=3
SHOW_LONGTERM_MEMORY_WRITES=false
SHOW_PLANNING_DEBUG=false

# ===== Backend =====
BACKEND_SAVE_REPORTS=true
BACKEND_REPORT_DIR=./reports
TASK_DEFAULT_TIMEOUT_S=1800
TASK_IDEMPOTENCY_TTL_S=1800
TASK_RESULT_CACHE_TTL_S=1800

# ===== Optional tracing =====
LANGSMITH_PROJECT=rag-eval
LANGSMITH_TRACE_RESEARCH=true
