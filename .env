#========模型设置=========
DASHSCOPE_API_KEY=

QWEN_MODEL_NAME=qwen-plus-2025-12-01

QWEN_TEMPERATURE=0.1

QWEN_MAX_TOKENS=2000

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

QWEN_TIMEOUT=30

QWEN_MAX_RETRIES=2

# ===== 报告生成专用参数（降低 report 节点超时概率）=====
REPORT_QWEN_TIMEOUT=180
REPORT_QWEN_MAX_RETRIES=1
REPORT_MAX_TOKENS=3200
REPORT_INPUT_MAX_CHARS=14000
#======搜索引擎设置=======
# serper = Serper.dev（Google 搜索结果 JSON，推荐）https://serper.dev
# tavily = Tavily（需 TAVILY_API_KEY）
SEARCH_BACKEND=serper
SERPER_API_KEY=

MAX_SEARCH_RESULTS=5

# 仍用 Tavily 时取消注释：SEARCH_BACKEND=tavily
# TAVILY_API_KEY=
#========向量嵌入工具设置=======
EMBEDDING_PROVIDER=dashscope

DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
#=======检索增强器设置=========
ENABLE_HYDE=true

HYDE_ANSWER_LENGTH=medium

ENABLE_MQE=false

MQE_NUM_VARIANTS=2
#=======深度评估参数设置========

METRIC_VALIDITY_WEIGHT=0.20
METRIC_SATURATION_WEIGHT=0.25
METRIC_DIVERSITY_WEIGHT=0.15
METRIC_CONFLICT_WEIGHT=0.05
METRIC_FACT_DENSITY_WEIGHT=0.20
METRIC_NOVELTY_WEIGHT=0.15

# =====研究决策阈值配置=======
TASK_STORAGE_THRESHOLD=80
CYCLE_CONTINUE_THRESHOLD=75
MAX_RESEARCH_CYCLES=3


SHOW_LONGTERM_MEMORY_WRITES=false
SHOW_PLANNING_DEBUG=false
SEARCH_LOG_QUERIES=false

MIN_TASK_STORAGE_THRESHOLD=65
TASK_STORAGE_THRESHOLD_DECAY_PER_CYCLE=6

RAG_EVAL_GOLD_PREVIEW_CHARS="6000"

# ===== RAG 检索评估 eval_report（与 data/rag_eval_ai_* 数据一致）=====
RAG_EVAL_DB_DIR=./data/rag_eval_ai_db
RAG_EVAL_QUERIES_PATH=./data/rag_eval_ai_queries_80.gold.jsonl
RAG_EVAL_RESEARCH_TOPIC=rag_eval_ai
RAG_EVAL_MODES=baseline,hyde,mqe
RAG_EVAL_WRITE_MD=0
RAG_EVAL_REPORT_JSON_PATH=./reports/rag_eval/final_eval.json
RAG_EVAL_TOP_K=8
RAG_EVAL_MQE_MERGE=rrf
RAG_EVAL_MQE_NUM_VARIANTS=2
RAG_EVAL_MQE_PER_VARIANT_K=22
RAG_EVAL_MQE_ORIG_POOL_MIN=48
RAG_EVAL_MQE_RRF_OVERLAP_BONUS=0.14
RAG_EVAL_HYDE_MERGE_ORIGINAL=1
RAG_EVAL_HYDE_FUSION=precision
RAG_EVAL_HYDE_ANSWER_LENGTH=short
RAG_EVAL_HYDE_POOL_MULT=3
RAG_EVAL_HYDE_POOL_MIN=30
RAG_EVAL_HYDE_PRECISION_REQUIRE_BOTH=1
RAG_EVAL_HYDE_ONLY_ORIG_WEIGHT=0.94
RAG_EVAL_HYDE_ONLY_HYP_WEIGHT=0.5

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=rag-eval
LANGSMITH_TRACE_RESEARCH=true

# ===== 后端任务自动落盘报告 =====
BACKEND_SAVE_REPORTS=true
BACKEND_REPORT_DIR=./reports